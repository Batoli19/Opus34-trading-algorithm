@{
    ViewData["Title"] = "About Us";
}

<section class="about-section" style="padding: 60px 0; background: #f7f7f7;">
    <div class="container" style="max-width: 900px; margin: auto;">

        <div style="text-align: center; margin-bottom: 40px;">
            <h1 style="font-size: 36px; margin-bottom: 10px; color: #333;">About FastLane Hypermarket</h1>
            <p style="font-size: 18px; color: #555;">
                Your trusted store for quality products, fast service, and unbeatable convenience.
            </p>
        </div>

        <div style="background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.08);">

            <h2 style="font-size: 28px; margin-bottom: 15px; color: #444;">Who We Are</h2>
            <p style="font-size: 17px; color: #555; line-height: 1.6;">
                FastLane Hypermarket is dedicated to providing customers with a wide range of quality products at
                competitive prices. We focus on excellent customer service, fast checkout, and a smooth shopping experience.
            </p>

            <hr style="margin: 30px 0;" />

            <h2 style="font-size: 28px; margin-bottom: 15px; color: #444;">Our Mission</h2>
            <p style="font-size: 17px; color: #555; line-height: 1.6;">
                Our mission is to make shopping easier, faster, and more enjoyable for everyone.
                Whether you're buying groceries, household items, or essentials, we ensure convenience at every step.
            </p>

            <hr style="margin: 30px 0;" />

            <h2 style="font-size: 28px; margin-bottom: 15px; color: #444;">Why Choose Us?</h2>
            <ul style="font-size: 17px; color: #555; line-height: 1.8; padding-left: 20px;">
                <li>✔ Wide selection of quality products</li>
                <li>✔ Affordable prices</li>
                <li>✔ Fast, friendly customer service</li>
                <li>✔ Convenient shopping experience online & in-store</li>
            </ul>

        </div>

    </div>
</section>
