<section class="dashboard-content fade-in">
    <!-- 🎯 Enhanced Header with Stats -->
    <div class="page-header-enhanced">
        <div class="header-main">
            <div class="header-title">
                <div class="title-icon">
                    <i class="fas fa-boxes"></i>
                </div>
                <div>
                    <h2>Products Management</h2>
                    <p class="subtitle">Manage your product inventory efficiently</p>
                </div>
            </div>
            <div class="header-stats">
                <div class="stat-card">
                    <div class="stat-icon total">
                        <i class="fas fa-cubes"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-number">@Model.Count()</span>
                        <span class="stat-label">Total Products</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon low-stock">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-number">@Model.Count(p => p.Quantity <= p.ReorderLevel && p.Quantity > 0)</span>
                        <span class="stat-label">Low Stock</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon out-of-stock">
                        <i class="fas fa-times-circle"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-number">@Model.Count(p => p.Quantity == 0)</span>
                        <span class="stat-label">Out of Stock</span>
                    </div>
