@model IEnumerable<FastLaneHypermarket.Models.Product>

@{
    Layout = "~/Views/Shared/LayoutDashboard.cshtml";
    ViewData["Title"] = "Products Management";
}

<style>
    :root {
        --bg-light: #f8fafc;
        --bg-white: #ffffff;
        --primary: #2563eb;
        --primary-light: #3b82f6;
        --primary-dark: #1d4ed8;
        --accent: #10b981;
        --text-dark: #1e293b;
        --text-light: #64748b;
        --border: #e2e8f0;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --shadow-lg: 0 10px 25px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }

    /* 🎯 Enhanced Styles */
    .page-header-enhanced {
        background: var(--bg-white);
        border-radius: 16px;
        padding: 32px;
        margin-bottom: 24px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
    }

    .header-main {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
    }

    .header-title {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .title-icon {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
    }

    .header-title h2 {
        color: var(--text-dark);
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
    }

    .subtitle {
        color: var(--text-light);
        margin: 8px 0 0 0;
        font-size: 16px;
    }

    .header-stats {
        display: flex;
        gap: 20px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
        background: var(--bg-white);
        border-radius: 12px;
        min-width: 180px;
        border: 1px solid var(--border);
        transition: all 0.3s ease;
        box-shadow: var(--shadow);
    }

        .stat-card:hover {
            border-color: var(--primary);
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
    }

        .stat-icon.total {
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
        }

        .stat-icon.low-stock {
            background: linear-gradient(135deg, var(--warning), #fbbf24);
        }

        .stat-icon.out-of-stock {
            background: linear-gradient(135deg, var(--danger), #ef4444);
        }

    .stat-number {
        font-size: 24px;
        font-weight: 800;
        display: block;
        line-height: 1;
        color: var(--text-dark);
    }

    .stat-label {
        font-size: 14px;
        color: var(--text-light);
        font-weight: 500;
    }

    .header-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }

    .search-container {
        position: relative;
        flex: 1;
        max-width: 500px;
    }

    .search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-light);
    }

    .search-input {
        width: 100%;
        padding: 14px 16px 14px 48px;
        border: 1px solid var(--border);
        border-radius: 10px;
        font-size: 16px;
        background: var(--bg-white);
        color: var(--text-dark);
        transition: all 0.3s ease;
        box-shadow: var(--shadow);
    }

        .search-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        .search-input::placeholder {
            color: var(--text-light);
        }

    .search-filters {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
    }

        .search-filters select {
            border: none;
            background: none;
            color: var(--text-light);
            font-size: 14px;
            background: var(--bg-white);
            padding: 4px 8px;
            border-radius: 6px;
        }

    .action-buttons {
        display: flex;
        gap: 12px;
    }

    .btn-primary, .btn-secondary, .btn-outline {
        padding: 12px 20px;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: white;
        box-shadow: var(--shadow);
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

    .btn-secondary {
        background: var(--bg-white);
        color: var(--text-dark);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }

        .btn-secondary:hover {
            border-color: var(--primary);
            color: var(--primary);
            transform: translateY(-2px);
        }

    .btn-outline {
        background: transparent;
        color: var(--text-light);
        border: 1px solid var(--border);
    }

        .btn-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

    /* Filter Panel */
    .filter-panel {
        background: var(--bg-white);
        border-radius: 16px;
        padding: 32px;
        margin-bottom: 24px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
    }

    .filter-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

        .filter-header h4 {
            color: var(--text-dark);
            margin: 0;
            font-size: 1.3rem;
            font-weight: 600;
        }

    .btn-close-filters {
        background: none;
        border: none;
        font-size: 20px;
        color: var(--text-light);
        cursor: pointer;
        padding: 8px;
        border-radius: 6px;
        transition: all 0.3s ease;
    }

        .btn-close-filters:hover {
            color: var(--primary);
            background: rgba(37, 99, 235, 0.1);
        }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 24px;
        margin-bottom: 24px;
    }

    .filter-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: var(--text-dark);
        font-size: 14px;
    }

    .filter-group select,
    .filter-group input {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg-white);
        color: var(--text-dark);
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .filter-group select:focus,
        .filter-group input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

    .price-range {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .price-range input {
            flex: 1;
        }

    .filter-actions {
        display: flex;
        gap: 16px;
        justify-content: flex-end;
    }

    /* Modal Styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.6);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 10000;
        backdrop-filter: blur(4px);
    }

    .modal-container {
        background: var(--bg-white);
        border: 1px solid var(--border);
        border-radius: 20px;
        width: 90%;
        max-width: 800px;
        max-height: 90vh;
        overflow-y: auto;
        animation: modalSlideIn 0.3s ease-out;
        box-shadow: var(--shadow-lg);
    }

    .modal-header {
        padding: 32px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header h3 {
            color: var(--text-dark);
            margin: 0;
            font-size: 1.6rem;
            font-weight: 700;
        }

    .modal-close {
        background: none;
        border: none;
        font-size: 20px;
        color: var(--text-light);
        cursor: pointer;
        padding: 8px;
        border-radius: 6px;
        transition: all 0.3s ease;
    }

        .modal-close:hover {
            color: var(--primary);
            background: rgba(37, 99, 235, 0.1);
        }

    .form-sections {
        padding: 0 32px;
    }

    .form-section {
        margin-bottom: 40px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 20px;
        color: var(--text-dark);
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .section-title i {
            color: var(--primary);
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        font-size: 14px;
        color: var(--text-dark);
    }

    .required {
        color: var(--danger);
    }

    .form-input, .form-select, .form-textarea {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        background: var(--bg-white);
        color: var(--text-dark);
    }

        .form-input:focus, .form-select:focus, .form-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

    .input-group {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-prefix, .input-suffix {
        padding: 12px;
        background: var(--bg-light);
        border: 1px solid var(--border);
        color: var(--text-light);
        font-size: 14px;
        font-weight: 500;
    }

    .input-prefix {
        border-right: none;
        border-radius: 8px 0 0 8px;
    }

    .input-suffix {
        border-left: none;
        border-radius: 0 8px 8px 0;
    }

    .input-group .form-input {
        border-radius: 0 8px 8px 0;
        flex: 1;
    }

        .input-group .form-input:not(:first-child) {
            border-radius: 8px 0 0 8px;
        }

    .form-hint {
        font-size: 12px;
        color: var(--text-light);
        margin-top: 6px;
    }

    .profit-indicator {
        font-size: 14px;
        color: var(--success);
        font-weight: 600;
        margin-top: 6px;
    }

    .media-upload {
        margin-bottom: 20px;
    }

    .upload-area {
        border: 2px dashed var(--border);
        border-radius: 12px;
        padding: 60px 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        background: var(--bg-light);
    }

        .upload-area:hover {
            border-color: var(--primary);
            background: rgba(37, 99, 235, 0.05);
        }

        .upload-area.dragover {
            border-color: var(--primary);
            background: rgba(37, 99, 235, 0.1);
        }

    .upload-icon {
        font-size: 56px;
        color: var(--text-light);
        margin-bottom: 16px;
    }

    .upload-text {
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-dark);
        font-size: 18px;
    }

    .upload-subtext {
        font-size: 14px;
        color: var(--text-light);
    }

    .file-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    .image-preview {
        display: flex;
        gap: 16px;
        margin-top: 20px;
        flex-wrap: wrap;
    }

        .image-preview img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
        }

    .form-actions {
        padding: 32px;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 16px;
    }

    /* Table Styles */
    .table-container-enhanced {
        background: var(--bg-white);
        border-radius: 16px;
        box-shadow: var(--shadow);
        overflow: hidden;
        border: 1px solid var(--border);
    }

    .table-header {
        padding: 24px 32px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--bg-light);
    }

    .table-info {
        font-size: 14px;
        color: var(--text-light);
        font-weight: 500;
    }

    .table-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .table-sort {
        padding: 8px 16px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        background: var(--bg-white);
        color: var(--text-dark);
        transition: all 0.3s ease;
    }

        .table-sort:focus {
            outline: none;
            border-color: var(--primary);
        }

    .btn-table-action {
        background: none;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 8px 12px;
        cursor: pointer;
        color: var(--text-light);
        transition: all 0.3s ease;
    }

        .btn-table-action:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(37, 99, 235, 0.1);
        }

    .table-wrapper {
        overflow-x: auto;
    }

    .styled-table-enhanced {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

        .styled-table-enhanced thead {
            background: var(--bg-light);
        }

        .styled-table-enhanced th {
            padding: 20px 16px;
            text-align: left;
            font-weight: 600;
            color: var(--text-dark);
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .styled-table-enhanced td {
            padding: 20px 16px;
            border-bottom: 1px solid var(--border);
            color: var(--text-dark);
        }

        .styled-table-enhanced tbody tr {
            transition: background-color 0.3s ease;
        }

            .styled-table-enhanced tbody tr:hover {
                background: rgba(37, 99, 235, 0.05);
            }

    .sortable {
        cursor: pointer;
        user-select: none;
        transition: background-color 0.3s ease;
    }

        .sortable:hover {
            background: rgba(37, 99, 235, 0.1);
        }

        .sortable span {
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .product-image {
        position: relative;
        width: 60px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .image-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
        color: white;
    }

    .product-image:hover .image-overlay {
        opacity: 1;
    }

    .product-name .name-wrapper {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .product-size {
        font-size: 12px;
        color: var(--text-light);
    }

    .category-tag {
        background: rgba(37, 99, 235, 0.1);
        color: var(--primary);
        padding: 6px 12px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid rgba(37, 99, 235, 0.2);
    }

    .price-wrapper {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .selling-price {
        font-weight: 700;
        color: var(--text-dark);
        font-size: 16px;
    }

    .cost-price {
        font-size: 12px;
        color: var(--text-light);
    }

    .stock-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .stock-quantity {
        font-weight: 700;
        min-width: 40px;
        color: var(--text-dark);
        font-size: 16px;
    }

    .stock-bar {
        width: 80px;
        height: 6px;
        background: var(--border);
        border-radius: 3px;
        overflow: hidden;
    }

    .stock-level {
        height: 100%;
        transition: width 0.3s ease;
    }

        .stock-level.high-stock {
            background: var(--success);
            width: 100%;
        }

        .stock-level.medium-stock {
            background: var(--warning);
            width: 60%;
        }

        .stock-level.low-stock {
            background: var(--danger);
            width: 30%;
        }

        .stock-level.out-of-stock {
            background: var(--text-light);
            width: 0%;
        }

    .status-badge {
        padding: 8px 12px;
        border-radius: 16px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-high {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .status-medium {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning);
        border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .status-low {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger);
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .status-out {
        background: rgba(100, 116, 139, 0.1);
        color: #64748b;
        border: 1px solid rgba(100, 116, 139, 0.2);
    }

    .date-cell {
        font-size: 14px;
    }

    .date {
        display: block;
        font-weight: 600;
        color: var(--text-dark);
    }

    .time {
        color: var(--text-light);
    }

    .actions-cell {
        white-space: nowrap;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .btn-action {
        background: none;
        border: none;
        padding: 8px;
        border-radius: 6px;
        cursor: pointer;
        color: var(--text-light);
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-action:hover {
            background: rgba(37, 99, 235, 0.1);
            transform: scale(1.1);
        }

    .btn-edit:hover {
        color: var(--primary);
    }

    .btn-view:hover {
        color: var(--success);
    }

    .btn-duplicate:hover {
        color: var(--warning);
    }

    .btn-delete:hover {
        color: var(--danger);
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: var(--text-light);
    }

        .empty-state i {
            font-size: 72px;
            margin-bottom: 20px;
            opacity: 0.5;
            color: var(--text-light);
        }

        .empty-state h3 {
            margin-bottom: 12px;
            color: var(--text-dark);
            font-size: 1.5rem;
            font-weight: 600;
        }

        .empty-state p {
            margin-bottom: 24px;
            font-size: 16px;
        }

    .pagination-container {
        padding: 24px 32px;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--bg-light);
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .pagination-btn {
        background: var(--bg-white);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 8px 12px;
        cursor: pointer;
        color: var(--text-dark);
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .pagination-btn:hover:not(:disabled) {
            border-color: var(--primary);
            color: var(--primary);
            background: rgba(37, 99, 235, 0.1);
        }

        .pagination-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .pagination-page {
        font-size: 14px;
        color: var(--text-light);
        font-weight: 500;
    }

    /* Animations */
    @@keyframes modalSlideIn {
        from

    {
        opacity: 0;
        transform: translateY(-20px) scale(0.95);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .fade-in {
        animation: fadeIn 0.5s ease-in-out;
    }

    /* Alerts */
    .alert {
        padding: 16px 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        border: 1px solid;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 500;
    }

    .alert-success {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
        border-color: rgba(16, 185, 129, 0.2);
    }

    .alert-danger {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger);
        border-color: rgba(239, 68, 68, 0.2);
    }

    /* Responsive Design */
    @@media (max-width: 1024px) {
        .header-main

    {
        flex-direction: column;
        gap: 24px;
    }

    .header-stats {
        width: 100%;
        justify-content: space-between;
    }

    .form-grid {
        grid-template-columns: 1fr;
    }

    }

    @@media (max-width: 768px) {
        .header-actions

    {
        flex-direction: column;
        align-items: stretch;
        gap: 16px;
    }

    .search-container {
        max-width: none;
    }

    .action-buttons {
        justify-content: space-between;
    }

    .table-header {
        flex-direction: column;
        gap: 16px;
        align-items: stretch;
    }

    .pagination-container {
        flex-direction: column;
        gap: 16px;
    }

    .page-header-enhanced {
        padding: 24px;
    }

    .modal-header,
    .form-sections,
    .form-actions {
        padding: 24px;
    }

    }

    @@media (max-width: 480px) {
        .header-stats

    {
        flex-direction: column;
        gap: 12px;
    }

    .stat-card {
        min-width: auto;
        width: 100%;
    }

    .action-buttons {
        flex-direction: column;
