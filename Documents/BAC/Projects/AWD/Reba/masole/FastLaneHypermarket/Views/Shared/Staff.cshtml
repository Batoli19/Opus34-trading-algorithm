@model List<FastLaneHypermarket.Models.Staff>
@{
    Layout = "~/Views/Shared/LayoutDashboard.cshtml";
    ViewData["Title"] = "Staff Management";
}

<section class="fade-in">
    <!-- Header Section -->
    <div class="page-header">
        <div class="header-content">
            <h2><i class="fas fa-user-tie"></i> Staff Management</h2>
            <p>Manage your team members and their access levels</p>
        </div>
        <div class="header-actions">
            <a href="/Account/Signup" class="btn-primary glow-on-hover">
                <i class="fas fa-user-plus"></i> Add New Staff
            </a>
        </div>
    </div>

    <!-- Enhanced Stats Overview -->
    <div class="stats-overview">
        <div class="stat-card">
            <div class="stat-icon total">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-info">
                <h3 id="totalStaff">@(Model?.Count ?? 0)</h3>
                <p>Total Staff</p>
                <div class="stat-trend">
                    <i class="fas fa-chart-line"></i>
                    <span>All team members</span>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon active">
                <i class="fas fa-user-check"></i>
            </div>
            <div class="stat-info">
                <h3 id="activeStaff">@(Model?.Count(s => s.StaffStatus == "Active") ?? 0)</h3>
                <p>Active Staff</p>
                <div class="stat-trend">
                    <i class="fas fa-bolt"></i>
                    <span>Currently working</span>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon inactive">
                <i class="fas fa-user-clock"></i>
            </div>
            <div class="stat-info">
                <h3 id="inactiveStaff">@(Model?.Count(s => s.StaffStatus == "Inactive") ?? 0)</h3>
                <p>Inactive Staff</p>
                <div class="stat-trend">
                    <i class="fas fa-pause"></i>
                    <span>On leave/terminated</span>
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon managers">
                <i class="fas fa-crown"></i>
            </div>
            <div class="stat-info">
                <h3 id="managerStaff">@(Model?.Count(s => s.Role == "Manager" || s.Role == "Admin") ?? 0)</h3>
                <p>Managers & Admins</p>
                <div class="stat-trend">
                    <i class="fas fa-shield-alt"></i>
                    <span>Administrative roles</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
        <div class="action-item" onclick="location.href='/Account/Signup'">
            <div class="action-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <div class="action-content">
                <h4>Add New Staff</h4>
                <p>Register a new team member</p>
            </div>
            <div class="action-arrow">
                <i class="fas fa-chevron-right"></i>
            </div>
        </div>
        <div class="action-item" onclick="exportStaffData()">
            <div class="action-icon">
                <i class="fas fa-file-export"></i>
            </div>
            <div class="action-content">
                <h4>Export Data</h4>
                <p>Download staff list as CSV</p>
            </div>
            <div class="action-arrow">
                <i class="fas fa-chevron-right"></i>
            </div>
        </div>
        <div class="action-item" onclick="showRecentHires()">
            <div class="action-icon">
                <i class="fas fa-history"></i>
            </div>
            <div class="action-content">
                <h4>Recent Activity</h4>
                <p>View recent staff changes</p>
            </div>
            <div class="action-arrow">
                <i class="fas fa-chevron-right"></i>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            <span>@TempData["Success"]</span>
            <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">
            <i class="fas fa-exclamation-circle"></i>
            <span>@TempData["Error"]</span>
            <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
        </div>
    }

    <!-- Enhanced Staff Table -->
    <div class="table-container">
        <div class="table-header">
            <div class="table-title">
                <h3><i class="fas fa-list"></i> Staff Members</h3>
                <span class="table-subtitle">@(Model?.Count ?? 0) team members</span>
            </div>
            <div class="table-controls">
                <div class="search-box with-filters">
                    <i class="fas fa-search"></i>
                    <input type="text" id="searchInput" placeholder="Search staff by name, email, or role...">
                    <select id="filterStatus" onchange="filterTable()">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                    <select id="filterRole" onchange="filterTable()">
                        <option value="">All Roles</option>
                        <option value="Manager">Manager</option>
                        <option value="Admin">Admin</option>
                        <option value="Staff">Staff</option>
                        <option value="Cashier">Cashier</option>
                    </select>
                </div>
                <div class="table-actions">
                    <button class="btn-secondary" onclick="printTable()" title="Print">
                        <i class="fas fa-print"></i>
                    </button>
                    <button class="btn-secondary" id="refreshBtn" title="Refresh">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="staff-table" id="staffTable">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="id">
                            <span>Staff ID</span>
                            <i class="fas fa-sort"></i>
                        </th>
                        <th class="sortable" data-sort="name">
                            <span>Team Member</span>
                            <i class="fas fa-sort"></i>
                        </th>
                        <th>Contact</th>
                        <th class="sortable" data-sort="role">
                            <span>Position</span>
                            <i class="fas fa-sort"></i>
                        </th>
                        <th class="sortable" data-sort="status">
                            <span>Status</span>
                            <i class="fas fa-sort"></i>
                        </th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="staffTableBody">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var staff in Model)
                        {
                            <tr data-staff-id="@staff.StaffId" data-status="@staff.StaffStatus" data-role="@staff.Role">
                                <td class="staff-id">
                                    <div class="id-badge">#@staff.StaffId</div>
                                </td>
                                <td class="staff-info">
                                    <div class="staff-avatar">
                                        <div class="avatar-img">
                                            @GetInitials(staff.Firstname, staff.Surname)
                                        </div>
                                    </div>
                                    <div class="staff-details">
                                        <div class="staff-name">
                                            <strong>@staff.Firstname @staff.Surname</strong>
                                            @if (staff.Role == "Manager" || staff.Role == "Admin")
                                            {
                                                <span class="badge-admin"><i class="fas fa-crown"></i> @staff.Role</span>
                                            }
                                        </div>
                                        <div class="staff-meta">
                                            <span class="gender-tag">@staff.Gender</span>
                                            <span class="dot">•</span>
                                            <span class="join-date">Member since @GetJoinDate(staff)</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="contact-info">
                                    <div class="contact-item">
                                        <i class="fas fa-envelope"></i>
                                        <a href="mailto:@staff.Email">@staff.Email</a>
                                    </div>
                                    <div class="contact-item">
                                        <i class="fas fa-phone"></i>
                                        <span>@staff.CellNumber</span>
                                    </div>
                                </td>
                                <td class="position-info">
                                    <div class="role-display">
                                        <span class="role-icon @GetRoleIcon(staff.Role)"></span>
                                        <div>
                                            <div class="role-title">@staff.Role</div>
                                            <div class="department">Operations</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="status-cell">
                                    <div class="status-container">
                                        <span class="status-badge @(staff.StaffStatus?.ToLower() == "active" ? "active" : "inactive")" id="status-@staff.StaffId">
                                            <i class="fas fa-circle"></i>
                                            @staff.StaffStatus
                                        </span>
                                        <div class="status-indicator @(staff.StaffStatus?.ToLower() == "active" ? "online" : "offline")"></div>
                                    </div>
                                </td>
                                <td class="actions">
                                    <div class="action-menu">
                                        <button class="btn-action btn-menu" onclick="toggleActionMenu(@staff.StaffId)">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <div class="action-dropdown" id="menu-@staff.StaffId">
                                            <button class="dropdown-item" onclick="viewStaff(@staff.StaffId)">
                                                <i class="fas fa-eye"></i> View Details
                                            </button>
                                            <button class="dropdown-item" onclick="editStaff(@staff.StaffId)">
                                                <i class="fas fa-edit"></i> Edit Profile
                                            </button>
                                            @if (staff.StaffStatus == "Active")
                                            {
                                                <button class="dropdown-item warning" onclick="toggleStaffStatus(@staff.StaffId)">
                                                    <i class="fas fa-ban"></i> Deactivate
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="dropdown-item success" onclick="toggleStaffStatus(@staff.StaffId)">
                                                    <i class="fas fa-check"></i> Activate
                                                </button>
                                            }
                                            <button class="dropdown-item danger" onclick="sendMessage(@staff.StaffId)">
                                                <i class="fas fa-envelope"></i> Send Message
                                            </button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="no-data">
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="fas fa-user-tie"></i>
                                    </div>
                                    <h4>No Staff Members Found</h4>
                                    <p>Your team is empty. Start building your team by adding the first staff member.</p>
                                    <a href="/Account/Signup" class="btn-primary">
                                        <i class="fas fa-user-plus"></i> Add First Team Member
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Enhanced Pagination -->
        <div class="table-footer">
            <div class="pagination-info">
                Showing <strong>@(Model?.Count ?? 0)</strong> of <strong>@(Model?.Count ?? 0)</strong> staff members
            </div>
            <div class="pagination-controls">
                <button class="page-btn" disabled>
                    <i class="fas fa-chevron-left"></i> Previous
                </button>
                <span class="page-numbers">
                    <span class="page-current">1</span>
                    of
                    <span class="page-total">1</span>
                </span>
                <button class="page-btn" disabled>
                    Next <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Quick View Modal -->
<div class="modal" id="quickViewModal">
    <div class="modal-content large">
        <div class="modal-header">
            <h3>Staff Details</h3>
            <span class="close-modal" onclick="closeQuickView()">&times;</span>
        </div>
        <div class="modal-body" id="quickViewContent">
            <!-- Content loaded dynamically -->
        </div>
    </div>
</div>

@functions {
    private string GetInitials(string firstname, string surname)
    {
        if (string.IsNullOrEmpty(firstname) || string.IsNullOrEmpty(surname))
            return "US";

        return $"{firstname[0]}{surname[0]}".ToUpper();
    }

    private string GetJoinDate(FastLaneHypermarket.Models.Staff staff)
    {
        // You might want to add a DateJoined field to your Staff model
        // For now, using a placeholder
        return DateTime.Now.AddMonths(-new Random().Next(1, 12)).ToString("MMM yyyy");
    }

    private string GetRoleIcon(string role)
    {
        return role?.ToLower() switch
        {
            "manager" => "fas fa-crown",
            "admin" => "fas fa-shield-alt",
            "cashier" => "fas fa-cash-register",
            _ => "fas fa-user"
        };
    }
}

<style>
    /* Enhanced Modern Styles */
    .fade-in {
        animation: fadeInUp 0.6s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Header Styles */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 30px;
        padding: 30px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 16px;
        color: white;
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
    }

    .header-content h2 {
        color: white;
        font-size: 28px;
        margin-bottom: 8px;
        font-weight: 700;
    }

    .header-content p {
        color: rgba(255,255,255,0.9);
        margin: 0;
        font-size: 16px;
    }

    .header-actions {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    /* Enhanced Stats Overview */
    .stats-overview {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        padding: 25px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        }

    .stat-icon {
        width: 70px;
        height: 70px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin-bottom: 15px;
        position: relative;
    }

        .stat-icon.total {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }

        .stat-icon.active {
            background: linear-gradient(135deg, #4CAF50, #45a049);
            color: white;
        }

        .stat-icon.inactive {
            background: linear-gradient(135deg, #ff9800, #f57c00);
            color: white;
        }

        .stat-icon.managers {
            background: linear-gradient(135deg, #9C27B0, #7B1FA2);
            color: white;
        }

    .stat-info h3 {
        font-size: 32px;
        margin: 0 0 5px 0;
        color: #2c3e50;
        font-weight: 700;
    }

    .stat-info p {
        margin: 0 0 8px 0;
        color: #6c757d;
        font-weight: 600;
    }

    .stat-trend {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: #888;
    }

    /* Quick Actions */
    .quick-actions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .action-item {
        background: white;
        padding: 25px;
        border-radius: 12px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 2px 15px rgba(0,0,0,0.06);
        display: flex;
        align-items: center;
        gap: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .action-item:hover {
            transform: translateX(5px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            border-left: 4px solid #667eea;
        }

    .action-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
    }

    .action-content {
        flex: 1;
    }

        .action-content h4 {
            margin: 0 0 5px 0;
            color: #2c3e50;
            font-weight: 600;
        }

        .action-content p {
            margin: 0;
            color: #6c757d;
            font-size: 14px;
        }

    .action-arrow {
        color: #6c757d;
        font-size: 14px;
    }

    /* Enhanced Table Styles */
    .table-container {
        background: white;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        overflow: hidden;
        margin-bottom: 30px;
    }

    .table-header {
        padding: 25px;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        background: #f8f9fa;
    }

    .table-title h3 {
        margin: 0 0 5px 0;
        color: #2c3e50;
        font-weight: 600;
    }

    .table-subtitle {
        color: #6c757d;
        font-size: 14px;
    }

    .table-controls {
        display: flex;
        justify-content: between;
        align-items: center;
        gap: 15px;
        margin-top: 15px;
    }

    .search-box.with-filters {
        display: flex;
        gap: 10px;
        flex: 1;
        max-width: 600px;
    }

        .search-box.with-filters input {
            flex: 1;
        }

        .search-box.with-filters select {
            width: 140px;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 8px;
            background: white;
        }

    /* Enhanced Table Content */
    .staff-info {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .staff-avatar .avatar-img {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 14px;
    }

    .staff-details {
        flex: 1;
    }

    .staff-name {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
    }

        .staff-name strong {
            color: #2c3e50;
            font-weight: 600;
        }

    .badge-admin {
        background: linear-gradient(135deg, #9C27B0, #7B1FA2);
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
    }

    .staff-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: #6c757d;
    }

    .gender-tag {
        background: #e9ecef;
        padding: 2px 8px;
        border-radius: 8px;
        font-size: 11px;
    }

    .dot {
        color: #adb5bd;
    }

    .contact-info {
        font-size: 13px;
    }

    .contact-item {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
    }

        .contact-item a {
            color: #495057;
            text-decoration: none;
        }

            .contact-item a:hover {
                color: #667eea;
            }

    .role-display {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .role-icon {
        width: 35px;
        height: 35px;
        border-radius: 8px;
        background: #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #495057;
    }

    .role-title {
        font-weight: 600;
        color: #2c3e50;
        font-size: 14px;
    }

    .department {
        font-size: 12px;
        color: #6c757d;
    }

    .status-container {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .status-indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

        .status-indicator.online {
            background: #4CAF50;
        }

        .status-indicator.offline {
            background: #ff9800;
        }

    /* Enhanced Action Menu */
    .action-menu {
        position: relative;
    }

    .btn-menu {
        background: none;
        border: 1px solid #e9ecef;
        padding: 8px;
        border-radius: 6px;
        cursor: pointer;
        color: #6c757d;
        transition: all 0.3s ease;
    }

        .btn-menu:hover {
            background: #f8f9fa;
            border-color: #667eea;
            color: #667eea;
        }

    .action-dropdown {
        position: absolute;
        top: 100%;
        right: 0;
        background: white;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        padding: 8px;
        min-width: 180px;
        z-index: 100;
        display: none;
    }

        .action-dropdown.show {
            display: block;
        }

    .dropdown-item {
        width: 100%;
        background: none;
        border: none;
        padding: 10px 12px;
        text-align: left;
        cursor: pointer;
        border-radius: 6px;
        color: #495057;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .dropdown-item:hover {
            background: #f8f9fa;
            color: #667eea;
        }

        .dropdown-item.warning:hover {
            background: #fff3cd;
            color: #856404;
        }

        .dropdown-item.success:hover {
            background: #d4edda;
            color: #155724;
        }

        .dropdown-item.danger:hover {
            background: #f8d7da;
            color: #721c24;
        }

    /* Table Footer */
    .table-footer {
        padding: 20px 25px;
        border-top: 1px solid rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f8f9fa;
    }

    .pagination-info {
        color: #6c757d;
        font-size: 14px;
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-btn {
        padding: 8px 16px;
        border: 1px solid #dee2e6;
        background: white;
        color: #495057;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .page-btn:not(:disabled):hover {
            background: #667eea;
            border-color: #667eea;
            color: white;
        }

        .page-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .page-numbers {
        color: #6c757d;
        font-size: 14px;
    }

    .page-current {
        font-weight: 600;
