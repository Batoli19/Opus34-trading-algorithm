@model List<FastLaneHypermarket.Models.Product>

@{
    ViewData["Title"] = "Home";
    var featured = Model?.Take(8).ToList() ?? new List<FastLaneHypermarket.Models.Product>();
}

<style>
    :root {
        --brand-orange: #ff7b00;
        --brand-orange-dark: #e06600;
        --text-dark: #222;
        --text-muted: #666;
        --bg-soft: #fafafa;
        --border: #e5e5e5;
        --shadow: 0 4px 12px rgba(0,0,0,0.08);
    }

    /* HERO SECTION */
    .hero {
        width: 100%;
        padding: 60px 0;
        background: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 40px;
        max-width: 1300px;
        margin: auto;
    }

    .hero-left {
        flex: 1;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 14px;
    }

    .hero-sub {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin-bottom: 24px;
        max-width: 450px;
    }

    .hero-btn {
        background: var(--brand-orange);
        padding: 12px 30px;
        color: white;
        border-radius: 8px;
        font-size: 1rem;
        text-decoration: none;
        font-weight: 600;
        transition: 0.2s;
    }

    .hero-btn:hover {
        background: var(--brand-orange-dark);
    }

    .hero-right img {
        width: 420px;
        border-radius: 10px;
        box-shadow: var(--shadow);
    }

    /* SECTION TITLE */
    .section-title {
        text-align: center;
        margin-top: 60px;
        margin-bottom: 30px;
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--text-dark);
    }

    /* NEW PRODUCT GRID */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 24px;
        max-width: 1200px;
        margin: auto;
        padding: 0 20px 60px;
    }

    .product-card {
        border: 1px solid var(--border);
        background: white;
        border-radius: 10px;
        padding-bottom: 15px;
        transition: 0.2s;
        cursor: pointer;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow);
    }

    .product-card img {
        width: 100%;
        height: 210px;
        object-fit: cover;
        border-radius: 10px 10px 0 0;
        background: #f5f5f5;
    }

    .product-name {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 12px 15px 4px;
        color: var(--text-dark);
    }

    .product-price {
        color: var(--brand-orange);
        margin: 0 15px 12px;
        font-weight: 700;
    }

    .product-actions {
        display: flex;
        gap: 10px;
        padding: 0 15px;
    }

    .btn-add {
        flex: 1;
        background: var(--brand-orange);
        border: none;
        color: white;
        padding: 10px;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-add:hover {
        background: var(--brand-orange-dark);
    }

    .btn-view {
        flex: 1;
        border: 1px solid var(--border);
        background: white;
        padding: 10px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .hero {
            flex-direction: column;
            text-align: center;
        }

        .hero-right img {
            width: 100%;
        }
    }
</style>


<!-- HERO -->
<section class="hero">
    <div class="hero-left">
        <h1 class="hero-title">Shop Smart. Live Better.</h1>
        <p class="hero-sub">
            Fresh deals, premium products, and fast delivery — all in one trusted hypermarket.
        </p>
        <a asp-controller="Home" asp-action="Products" class="hero-btn">
            Start Shopping
        </a>
    </div>

    <div class="hero-right">
        <img src="@(featured.FirstOrDefault()?.ImageUrl ?? "/images/products/default.jpg")" />
    </div>
</section>


<!-- FEATURED -->
<h2 class="section-title">Trending Products</h2>

<div class="product-grid">
    @foreach (var p in featured)
    {
        <div class="product-card">
            <img src="@p.ImageUrl"
                 onerror="this.src='/images/products/default.jpg'" />

            <div class="product-name">@p.ProductName</div>
            <div class="product-price">P @p.SellingPrice.ToString("N2")</div>

            <div class="product-actions">
                <button class="btn-add" onclick="addToCart(@p.ProductCode)">
                    Add
