@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">An error occurred while processing your request.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Development Mode</h3>
<p>
    Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
</p>
<p>
    <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
    It can result in displaying sensitive information from exceptions to end users.
    For local debugging, enable the <strong>Development</strong> environment by setting the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong>
    and restarting the app.
</p>


<style>
    /* ---------- Theme palette ---------- */
    :root {
        --bg: #07060a;
        --panel: #0f0d13;
        --muted: #bfc7d6;
        --accent: #f5c84a; /* gold */
        --accent-2: #9be7ff; /* neon blue */
        --glass: rgba(255,255,255,0.03);
        --radius: 14px;
        --card-shadow: 0 10px 30px rgba(2,2,5,0.6);
        --glass-2: rgba(255,255,255,0.02);
    }

    /* ---------- Layout ---------- */
    .nm-wrap {
        background: radial-gradient(1200px 400px at 10% 10%, rgba(155,135,53,0.06), transparent), var(--bg);
        color: var(--muted);
        min-height: 100vh;
        font-family: Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial;
    }

    .nm-hero {
        padding: 48px 0 10px;
    }

    .nm-hero-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        text-align: center;
    }

    .nm-hero-title {
        font-size: 36px;
        color: var(--accent);
        margin: 0 0 6px;
        letter-spacing: -0.6px;
        font-weight: 800;
        text-shadow: 0 6px 30px rgba(245,200,74,0.06);
    }

    .nm-hero-sub {
        margin: 0 0 18px;
        opacity: 0.9;
        color: #d5d9e6;
    }

    /* search row */
    .nm-hero-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .nm-search {
        padding: 12px 16px;
        min-width: 340px;
        border-radius: 10px;
        background: var(--panel);
        border: 1px solid var(--glass);
        color: var(--muted);
        outline: none;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
    }

    .nm-select {
        padding: 12px 14px;
        border-radius: 10px;
        background: var(--panel);
        border: 1px solid var(--glass);
        color: var(--muted);
    }

    /* container and grid */
    .Product-container {
        max-width: 1200px;
        margin: 28px auto;
        padding: 0 20px 80px;
    }

    .PRoduct-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 18px;
        align-items: start;
    }

    /* card */
    .Product-card {
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
        border: 1px solid var(--glass-2);
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--card-shadow);
        transition: transform .35s cubic-bezier(.2,.9,.2,1), box-shadow .35s;
        display: flex;
        flex-direction: column;
    }

        .nm-card:hover {
            transform: translateY(-10px) scale(1.01);
            box-shadow: 0 20px 50px rgba(2,2,5,0.7);
        }

    /* top media */
    .nm-media {
        position: relative;
        height: 180px;
        display: block;
        overflow: hidden;
    }

        .nm-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform .45s;
        }

    .nm-card:hover .nm-media img {
        transform: scale(1.07);
    }

    /* gold ribbon */
    .nm-badge {
        position: absolute;
        left: 12px;
        top: 12px;
        background: linear-gradient(90deg,var(--accent), #f6e28f);
        color: #081018;
        padding: 7px 12px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 12px;
        box-shadow: 0 6px 18px rgba(245,200,74,0.08);
    }

    /* info area */
    .nm-info {
        padding: 14px 16px 18px;
        display: flex;
        gap: 12px;
        flex-direction: column;
        height: 1%;
    }

    .nm-title {
        font-weight: 700;
        color: #e6e9f2;
        margin: 0 0 6px;
        font-size: 1rem;
    }

    .nm-category {
        font-size: 12px;
        color: var(--accent-2);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }

    .nm-size {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 6px;
    }

    /* price & stock */
    .nm-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
    }

    .nm-price {
        font-weight: 800;
        color: var(--accent);
        font-size: 1.15rem;
    }

    .nm-cost {
        font-size: 12px;
        text-decoration: line-through;
        color: #9aa3b9;
        margin-left: 8px;
    }

    /* actions */
    .nm-actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
    }

    .nm-btn {
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid transparent;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        font-weight: 700;
        font-size: 13px;
        transition: all .25s;
    }

        .nm-btn:hover {
            transform: translateY(-3px);
        }

    .nm-btn-primary {
        background: linear-gradient(90deg,var(--accent), #f7d77a);
        color: #081018;
        border-color: rgba(255,255,255,0.06);
    }

    .nm-btn-ghost {
        border: 1px solid var(--glass);
        background: transparent;
    }

    /* small meta */
    .nm-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
        font-size: 13px;
        color: var(--muted);
    }

    /* Quick view modal */
    .nm-modal {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(2,2,5,0.6);
        z-index: 1200;
        opacity: 0;
        pointer-events: none;
        transition: opacity .25s;
    }

        .nm-modal[aria-hidden="false"] {
            opacity: 1;
            pointer-events: auto;
        }

    .nm-modal-panel {
        width: 90%;
        max-width: 1000px;
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
        border-radius: 14px;
        padding: 20px;
        display: flex;
        gap: 16px;
        border: 1px solid var(--glass-2);
        box-shadow: 0 30px 80px rgba(2,2,5,0.8);
    }

    .nm-modal-close {
        margin-left: auto;
        background: transparent;
        border: none;
        color: var(--muted);
        font-size: 20px;
        cursor: pointer;
    }

    .nm-modal-body {
        display: flex;
        gap: 18px;
        width: 100%;
    }

    .nm-quick-media {
        width: 48%;
        height: 420px;
        background: #0a0a0a;
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .nm-quick-media img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

    .nm-quick-info {
        width: 52%;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .nm-desc {
        color: var(--muted);
        margin-top: 8px;
    }

    /* empty state */
    .nm-empty {
        text-align: center;
        color: var(--muted);
        padding: 60px 20px;
    }

    /* responsive */
    2@media (max-width:820px) {
        .nm-modal-panel

    {
        flex-direction: column;
        padding: 12px;
    }

    .nm-quick-media {
        width: 100%;
        height: 300px;
    }

    .nm-quick-info {
        width: 100%;
    }

    }
</style>
