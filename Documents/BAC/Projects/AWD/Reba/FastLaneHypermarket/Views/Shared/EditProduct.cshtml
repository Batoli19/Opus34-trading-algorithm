@model FastLaneHypermarket.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/LayoutDashboard.cshtml";
}

<style>
    .edit-product-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
    }

    .card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        margin-bottom: 30px;
    }

    .card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 15px 15px 0 0 !important;
        padding: 20px 30px;
        border: none;
    }

    .card-body {
        padding: 30px;
    }

    .section-title {
        color: #2c3e50;
        font-weight: 600;
        margin-bottom: 25px;
        padding-bottom: 10px;
        border-bottom: 2px solid #3498db;
    }

    .form-label {
        font-weight: 600;
        color: #34495e;
        margin-bottom: 8px;
    }

    .form-control {
        border: 2px solid #ecf0f1;
        border-radius: 8px;
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25);
        }

    .btn {
        padding: 12px 30px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-success {
        background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
    }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(39, 174, 96, 0.4);
        }

    .btn-outline-danger {
        border: 2px solid #e74c3c;
        color: #e74c3c;
    }

        .btn-outline-danger:hover {
            background: #e74c3c;
            color: white;
            transform: translateY(-2px);
        }

    .btn-secondary {
        background: #95a5a6;
    }

        .btn-secondary:hover {
            background: #7f8c8d;
            transform: translateY(-2px);
        }

    .validation-summary {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
    }

    .field-validation-error {
        color: #e74c3c;
        font-size: 0.875rem;
        margin-top: 5px;
        display: block;
    }

    .input-group {
        position: relative;
    }

    .input-group-text {
        background: #f8f9fa;
        border: 2px solid #ecf0f1;
        border-right: none;
    }

    .form-control.with-prefix {
        border-left: none;
    }

    .stock-indicator {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .stock-low {
        background: #fff3cd;
        color: #856404;
    }

    .stock-out {
        background: #f8d7da;
        color: #721c24;
    }

    .stock-good {
        background: #d1ecf1;
        color: #0c5460;
    }

    .price-calculation {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 15px;
        margin-top: 10px;
    }

    .calculation-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 5px;
        font-size: 0.9rem;
    }

    .profit-amount {
        color: #27ae60;
        font-weight: 600;
    }

    .profit-percentage {
        color: #e67e22;
        font-weight: 600;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .edit-product-container {
            padding: 10px;
        }

        .card-body {
            padding: 20px;
        }

        .btn {
            width: 100%;
            margin-bottom: 10px;
            justify-content: center;
        }

        .action-buttons {
            flex-direction: column;
        }
    }

    @@media (max-width: 576px) {
        .card-body {
            padding: 15px;
        }

        .section-title {
            font-size: 1.3rem;
        }
    }
</style>

<div class="edit-product-container">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Edit Product</h2>
            <p class="text-muted mb-0">Update product information and pricing</p>
        </div>
        <a href="@Url.Action("StaffProducts", "Staff")" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Products
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Edit Form -->
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Product Details</h4>
        </div>
        <div class="card-body">
            <form method="post" asp-action="EditProduct" id="editProductForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductCode" />
                <input type="hidden" asp-for="DatePurchased" />
                <input type="hidden" asp-for="RecordedBy" />

                <div class="row">
                    <!-- Product Information -->
                    <div class="col-lg-6">
                        <h5 class="section-title"><i class="fas fa-info-circle me-2"></i>Product Information</h5>

                        <div class="mb-3">
                            <label asp-for="ProductName" class="form-label">Product Name *</label>
                            <input asp-for="ProductName" class="form-control" placeholder="Enter product name" required />
                            <span asp-validation-for="ProductName" class="field-validation-error"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category" class="form-label">Category *</label>
                            <select asp-for="Category" class="form-control" required>
                                <option value="">Select Category</option>
                                <option value="Groceries">Groceries</option>
                                <option value="Electricals">Electricals</option>
                                <option value="Farming">Farming</option>
                                <option value="Furniture">Furniture</option>
                                <option value="Motoring">Motoring</option>
                                <option value="Chemicals">Chemicals</option>
                                <option value="Clothing">Clothing</option>
                            </select>
                            <span asp-validation-for="Category" class="field-validation-error"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Size" class="form-label">Size/Weight</label>
                            <input asp-for="Size" class="form-control" placeholder="e.g., 500g, 1L, Large, Medium" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductStatus" class="form-label">Product Status</label>
                            <select asp-for="ProductStatus" class="form-control">
                                <option value="Active">Active</option>
                                <option value="Discontinued">Discontinued</option>
                                <option value="OutOfStock">Out of Stock</option>
                            </select>
                        </div>
                    </div>

                    <!-- Stock & Pricing -->
                    <div class="col-lg-6">
                        <h5 class="section-title"><i class="fas fa-chart-line me-2"></i>Stock & Pricing</h5>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Quantity" class="form-label">Current Stock *</label>
                                    <input asp-for="Quantity" type="number" class="form-control" min="0" required
                                           onchange="updateStockIndicator()" />
                                    <span asp-validation-for="Quantity" class="field-validation-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ReorderLevel" class="form-label">Reorder Level *</label>
                                    <input asp-for="ReorderLevel" type="number" class="form-control" min="0" required />
                                    <span asp-validation-for="ReorderLevel" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PurchasePrice" class="form-label">Purchase Price (P) *</label>
                            <div class="input-group">
                                <span class="input-group-text">P</span>
                                <input asp-for="PurchasePrice" type="number" step="0.01" class="form-control with-prefix"
                                       min="0" required onchange="calculateProfit()" />
                            </div>
                            <span asp-validation-for="PurchasePrice" class="field-validation-error"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SellingPrice" class="form-label">Selling Price (P) *</label>
                            <div class="input-group">
                                <span class="input-group-text">P</span>
                                <input asp-for="SellingPrice" type="number" step="0.01" class="form-control with-prefix"
                                       min="0" required onchange="calculateProfit()" />
                            </div>
                            <span asp-validation-for="SellingPrice" class="field-validation-error"></span>
                        </div>

                        <!-- Profit Calculation -->
                        <div class="price-calculation">
                            <div class="calculation-row">
                                <span>Profit per item:</span>
                                <span id="profitAmount" class="profit-amount">P0.00</span>
                            </div>
                            <div class="calculation-row">
                                <span>Profit margin:</span>
                                <span id="profitPercentage" class="profit-percentage">0%</span>
                            </div>
                            <div class="calculation-row">
                                <span>Stock status:</span>
                                <span id="stockIndicator" class="stock-indicator stock-good">Good</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Additional Information -->
                <div class="row mt-4">
                    <div class="col-12">
                        <h5 class="section-title"><i class="fas fa-clipboard-list me-2"></i>Additional Information</h5>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Date Added</label>
                                    <input type="text" class="form-control" value="@Model.DatePurchased.ToString("MMMM dd, yyyy")" readonly />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Recorded By</label>
                                    <input type="text" class="form-control" value="@Model.RecordedBy" readonly />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="d-flex gap-2 action-buttons">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Update Product
                            </button>
                            <button type="reset" class="btn btn-outline-secondary">
                                <i class="fas fa-redo"></i> Reset Changes
                            </button>
                            <a href="@Url.Action("StaffProducts", "Staff")" class="btn btn-outline-danger">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Calculate profit and update display
        function calculateProfit() {
            const purchasePrice = parseFloat(document.getElementById('PurchasePrice').value) || 0;
            const sellingPrice = parseFloat(document.getElementById('SellingPrice').value) || 0;

            if (purchasePrice > 0 && sellingPrice > 0) {
                const profit = sellingPrice - purchasePrice;
                const profitPercentage = ((profit / purchasePrice) * 100);

                document.getElementById('profitAmount').textContent = 'P' + profit.toFixed(2);
                document.getElementById('profitPercentage').textContent = profitPercentage.toFixed(1) + '%';
            } else {
                document.getElementById('profitAmount').textContent = 'P0.00';
                document.getElementById('profitPercentage').textContent = '0%';
            }
        }

        // Update stock indicator
        function updateStockIndicator() {
            const quantity = parseInt(document.getElementById('Quantity').value) || 0;
            const reorderLevel = parseInt(document.getElementById('ReorderLevel').value) || 0;
            const stockIndicator = document.getElementById('stockIndicator');

            if (quantity === 0) {
                stockIndicator.className = 'stock-indicator stock-out';
                stockIndicator.textContent = 'Out of Stock';
                stockIndicator.innerHTML = '<i class="fas fa-times-circle"></i> Out of Stock';
            } else if (quantity <= reorderLevel) {
                stockIndicator.className = 'stock-indicator stock-low';
                stockIndicator.textContent = 'Low Stock';
                stockIndicator.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Low Stock';
            } else {
                stockIndicator.className = 'stock-indicator stock-good';
                stockIndicator.textContent = 'Good Stock';
                stockIndicator.innerHTML = '<i class="fas fa-check-circle"></i> Good Stock';
            }
        }

        // Form validation
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize calculations
            calculateProfit();
            updateStockIndicator();

            const form = document.getElementById('editProductForm');
            form.addEventListener('submit', function(e) {
                const sellingPrice = parseFloat(document.getElementById('SellingPrice').value) || 0;
                const purchasePrice = parseFloat(document.getElementById('PurchasePrice').value) || 0;

                if (sellingPrice < purchasePrice) {
                    e.preventDefault();
                    showAlert('Selling price cannot be less than purchase price!', 'danger');
                    return false;
                }

                if (sellingPrice === 0) {
                    e.preventDefault();
                    showAlert('Please enter a valid selling price!', 'danger');
                    return false;
                }
            });
        });

        // Show custom alert
        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
            alertDiv.innerHTML = `
                <i class="fas fa-${type === 'danger' ? 'exclamation-triangle' : 'info-circle'} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;

            document.querySelector('.edit-product-container').insertBefore(alertDiv, document.querySelector('.card'));

            // Auto remove after 5 seconds
            setTimeout(() => {
                alertDiv.remove();
            }, 5000);
        }

        // Auto-select the correct category in dropdown
        document.addEventListener('DOMContentLoaded', function() {
            const category = '@Model.Category';
            if (category) {
                const categorySelect = document.getElementById('Category');
                for (let i = 0; i < categorySelect.options.length; i++) {
                    if (categorySelect.options[i].value === category) {
                        categorySelect.selectedIndex = i;
                        break;
                    }
                }
            }
        });
    </script>
}