@{
    ViewData["Title"] = "About Us";
}

<style>
    /* About Page Styling - White & Blue Theme */
    .about-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 24px;
        background: #ffffff;
        min-height: 100vh;
    }

    .about-header {
        text-align: center;
        margin-bottom: 50px;
        padding: 40px 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .about-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" fill="%23ffffff" opacity="0.1"><polygon points="1000,100 1000,0 0,100"/></svg>');
            background-size: cover;
        }

    .about-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 16px;
        position: relative;
        z-index: 2;
    }

    .about-subtitle {
        font-size: 1.3rem;
        opacity: 0.9;
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
        position: relative;
        z-index: 2;
        font-weight: 400;
    }

    .about-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        margin-bottom: 60px;
        align-items: start;
    }

    .about-text {
        color: #2d3748;
    }

        .about-text h3 {
            color: #2b6cb0;
            font-size: 2rem;
            margin-bottom: 20px;
            font-weight: 700;
        }

        .about-text p {
            font-size: 1.1rem;
            line-height: 1.7;
            margin-bottom: 20px;
            color: #4a5568;
        }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
        margin: 40px 0;
    }

    .feature-card {
        background: #f7fafc;
        padding: 30px;
        border-radius: 15px;
        text-align: center;
        border: 2px solid #e2e8f0;
        transition: all 0.3s ease;
    }

        .feature-card:hover {
            transform: translateY(-5px);
            border-color: #667eea;
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.1);
        }

    .feature-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 1.8rem;
        color: white;
    }

    .feature-title {
        color: #2b6cb0;
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .feature-desc {
        color: #718096;
        line-height: 1.6;
    }

    /* Location & Weather Section */
    .location-section {
        background: #f8fafc;
        padding: 40px;
        border-radius: 20px;
        margin: 40px 0;
        border: 2px solid #e2e8f0;
    }

    .section-title {
        color: #2b6cb0;
        font-size: 2rem;
        margin-bottom: 30px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .section-title i {
            font-size: 1.8rem;
        }

    .location-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
    }

    .location-info {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .btn-location {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 16px 32px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        width: fit-content;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

        .btn-location:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        }

        .btn-location:active {
            transform: translateY(0);
        }

    .location-text {
        background: white;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        font-family: 'Courier New', monospace;
        color: #2d3748;
        min-height: 60px;
        display: flex;
        align-items: center;
    }

    .weather-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }

    .weather-icon {
        font-size: 3rem;
        color: #667eea;
        margin-bottom: 15px;
    }

    .weather-info {
        color: #4a5568;
        line-height: 1.6;
    }

    .weather-temp {
        font-size: 2rem;
        font-weight: 700;
        color: #2b6cb0;
        margin: 10px 0;
    }

    .weather-desc {
        font-size: 1.1rem;
        color: #718096;
        margin-bottom: 10px;
    }

    .weather-location {
        color: #667eea;
        font-weight: 600;
    }

    /* Map Styling */
    .map-container {
        background: white;
        padding: 20px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        height: 400px;
        overflow: hidden;
    }

    .map-frame {
        width: 100%;
        height: 100%;
        border-radius: 10px;
        border: none;
    }

    /* Stats Section */
    .stats-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 60px 40px;
        border-radius: 20px;
        color: white;
        text-align: center;
        margin: 60px 0;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 40px;
        max-width: 800px;
        margin: 0 auto;
    }

    .stat-item {
        padding: 20px;
    }

    .stat-number {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 10px;
        background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.8) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .stat-label {
        font-size: 1.1rem;
        opacity: 0.9;
        font-weight: 500;
    }

    /* Responsive Design */
    @@media (max-width: 1024px) {
        .about-content {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .location-content {
            grid-template-columns: 1fr;
            gap: 30px;
        }
    }

    @@media (max-width: 768px) {
        .about-title {
            font-size: 2.8rem;
        }

        .features-grid {
            grid-template-columns: 1fr;
        }

        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .location-section {
            padding: 30px 20px;
        }
    }

    @@media (max-width: 480px) {
        .about-title {
            font-size: 2.2rem;
        }

        .about-header {
            padding: 30px 20px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .stat-number {
            font-size: 2.5rem;
        }
    }

    /* Additional Blue Accents */
    .divider {
        height: 3px;
        background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
        border: none;
        margin: 40px 0;
        border-radius: 2px;
    }

    .highlight {
        color: #2b6cb0;
        font-weight: 600;
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.1);
            border-color: #667eea;
        }
</style>

<div class="about-container">
    <!-- Header Section -->
    <div class="about-header">
        <h1 class="about-title">About FastLane Hypermarket</h1>
        <p class="about-subtitle">
            Your trusted online shopping solution for premium products, fast delivery, and exceptional service
        </p>
    </div>

    <!-- Main Content -->
    <div class="about-content">
        <div class="about-text">
            <h3>Our Story</h3>
            <p>
                Welcome to <span class="highlight">FastLane Hypermarket</span> — your premier destination for
                quality shopping experiences. Founded with a vision to revolutionize online retail, we bring
                you carefully curated products with unmatched convenience.
            </p>
            <p>
                Our commitment to excellence drives everything we do. From sourcing the finest products to
                ensuring swift delivery, we're dedicated to making your shopping journey seamless and enjoyable.
            </p>

            <h3>Why Choose Us?</h3>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-shipping-fast"></i>
                    </div>
                    <h4 class="feature-title">Fast Delivery</h4>
                    <p class="feature-desc">Get your orders delivered quickly with our optimized logistics network</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-award"></i>
                    </div>
                    <h4 class="feature-title">Quality Guaranteed</h4>
                    <p class="feature-desc">Every product is carefully selected and quality-checked</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h4 class="feature-title">24/7 Support</h4>
                    <p class="feature-desc">Our customer service team is always ready to assist you</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4 class="feature-title">Secure Shopping</h4>
                    <p class="feature-desc">Your data and transactions are protected with advanced security</p>
                </div>
            </div>
        </div>

        <div class="about-text">
            <h3>Our Mission</h3>
            <p>
                At FastLane Hypermarket, we believe that everyone deserves access to quality products
                without compromise. Our mission is to bridge the gap between premium shopping and
                convenience, bringing the best of both worlds to your fingertips.
            </p>

            <h3>What We Offer</h3>
            <p>
                Explore our extensive collection of products ranging from daily essentials to premium
                luxury items. Each category is thoughtfully curated to ensure you find exactly what
                you're looking for, with the quality you deserve.
            </p>

            <div class="card">
                <h4 style="color: #2b6cb0; margin-bottom: 15px;">Our Promise</h4>
                <p style="color: #4a5568; line-height: 1.6;">
                    We're committed to providing an exceptional shopping experience with competitive prices,
                    reliable service, and customer satisfaction at the core of everything we do.
                </p>
            </div>
        </div>
    </div>

    <!-- Stats Section -->
    <div class="stats-section">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-number">500+</div>
                <div class="stat-label">Premium Products</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">10K+</div>
                <div class="stat-label">Happy Customers</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">24/7</div>
                <div class="stat-label">Customer Support</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">99%</div>
                <div class="stat-label">Satisfaction Rate</div>
            </div>
        </div>
    </div>

    <!-- Location & Weather Section -->
    <div class="location-section">
        <h3 class="section-title">
            <i class="fas fa-map-marker-alt"></i>
            📍 My Location
        </h3>

        <div class="location-content">
            <div class="location-info">
                <button onclick="getLocation()" class="btn-location">
                    <i class="fas fa-location-arrow"></i>
                    Show My Location
                </button>

                <div class="location-text" id="location-text">
                    Click the button above to detect your location
                </div>

                <div class="weather-card">
                    <div class="weather-icon">
                        <i class="fas fa-cloud-sun"></i>
                    </div>
                    <div class="weather-info">
                        <h4 style="color: #2b6cb0; margin-bottom: 10px;">Local Weather</h4>
                        <div id="weather-text">
                            Click "Show My Location" to load weather information
                        </div>
                    </div>
                </div>
            </div>

            <div class="map-container">
                <div id="map" style="display: none;">
                    <!-- Map will be inserted here -->
                </div>
                <div id="map-placeholder" style="height: 100%; display: flex; align-items: center; justify-content: center; color: #718096; text-align: center;">
                    <div>
                        <i class="fas fa-map" style="font-size: 3rem; margin-bottom: 15px; color: #cbd5e0;"></i>
                        <p>Your map will appear here after location detection</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function getLocation() {
        if (!navigator.geolocation) {
            alert("Geolocation not supported by your browser.");
            return;
        }

        // Show loading state
        const locationText = document.getElementById("location-text");
        const weatherText = document.getElementById("weather-text");
        const mapPlaceholder = document.getElementById("map-placeholder");

        locationText.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Detecting your location...';
        weatherText.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading weather data...';

        navigator.geolocation.getCurrentPosition(success, error);
    }

    function success(position) {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;

        // Update location text
        const locationText = document.getElementById("location-text");
        locationText.innerHTML = `
            <div style="color: #2d3748;">
                <strong>📍 Coordinates Found</strong><br>
                <span style="color: #667eea;">Latitude:</span> ${lat.toFixed(6)}<br>
                <span style="color: #667eea;">Longitude:</span> ${lon.toFixed(6)}
            </div>
        `;

        // Show Google Map
        const mapContainer = document.getElementById("map");
        const mapPlaceholder = document.getElementById("map-placeholder");

        mapPlaceholder.style.display = "none";
        mapContainer.style.display = "block";
        mapContainer.innerHTML = `
            <iframe class="map-frame"
                src="https://maps.google.com/maps?q=${lat},${lon}&z=15&output=embed"
                allowfullscreen>
            </iframe>
        `;

        // Load Weather
        fetch(`/Home/GetWeather?lat=${lat}&lon=${lon}`)
            .then(res => res.json())
            .then(data => {
                const weatherText = document.getElementById("weather-text");
                weatherText.innerHTML = `
                    <div class="weather-temp">${data.temp}°C</div>
                    <div class="weather-desc">${data.desc}</div>
                    <div class="weather-location">📍 ${data.location}</div>
                `;
            })
            .catch(err => {
                document.getElementById("weather-text").innerHTML =
                    '❌ Unable to load weather data';
            });
    }

    function error() {
        const locationText = document.getElementById("location-text");
        const weatherText = document.getElementById("weather-text");

        locationText.innerHTML = '❌ Unable to retrieve your location. Please check your browser permissions.';
        weatherText.innerHTML = 'Weather data unavailable without location access.';
    }
</script>