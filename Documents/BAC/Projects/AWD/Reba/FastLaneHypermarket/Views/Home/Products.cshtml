@model List<FastLaneHypermarket.Models.Product>

<section class="products-showcase">
    <div class="container">
        <!-- Showcase Header -->
        <div class="showcase-header">
            <h1>Premium Products</h1>
            <p>Discover our curated collection of high-quality items</p>
        </div>

        <!-- Products Grid -->
        <div class="products-grid" id="productsGrid">
            @if (Model != null && Model.Any())
            {
                foreach (var p in Model)
                {
                    <div class="product-card" data-product-id="@p.ProductCode" data-category="@p.Category">
                        <div class="card-inner">
                            <!-- Front of Card -->
                            <div class="card-front">
                                <div class="img-wrap">
                                    <img src="@p.ImageUrl" alt="@p.ProductName"
                                         onerror="this.src='/images/products/default.jpg'" />
                                    <div class="category-chip">@p.Category</div>

                                    <!-- Stock Badge -->
                                    @if (p.Quantity == 0)
                                    {
                                        <div class="stock-badge out-of-stock">Out of Stock</div>
                                    }
                                    else if (p.Quantity <= p.ReorderLevel)
                                    {
                                        <div class="stock-badge low-stock">Low Stock</div>
                                    }
                                </div>

                                <div class="info">
                                    <h3 class="product-title">@p.ProductName</h3>

                                    @if (!string.IsNullOrEmpty(p.Size))
                                    {
                                        <p class="size">Size: @p.Size</p>
                                    }

                                    <div class="price-box">
                                        <span class="price">P @p.SellingPrice.ToString("N2")</span>
                                        @if (p.PurchasePrice > 0 && p.PurchasePrice < p.SellingPrice)
                                        {
                                            <span class="old-price">P @p.PurchasePrice.ToString("N2")</span>
                                        }
                                    </div>

                                    <div class="stock">
                                        <i class="fas fa-box"></i>
                                        <span>@(p.Quantity > 0 ? $"{p.Quantity} in stock" : "Out of Stock")</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Hover Actions -->
                            <div class="card-hover">
                                @if (p.Quantity > 0)
                                {
                                    <button class="btn-cart"
                                            onclick="event.stopPropagation(); addToCart(@p.ProductCode)">
                                        <i class="fas fa-cart-plus"></i> Add to Cart
                                    </button>

                                    <button class="btn-whatsapp"
                                            onclick="event.stopPropagation(); orderOnWhatsApp(@p.ProductCode, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(p.ProductName)), @p.SellingPrice)">
                                        <i class="fab fa-whatsapp"></i> Buy via WhatsApp
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-out" disabled>
                                        <i class="fas fa-times-circle"></i> Out of Stock
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-box-open"></i>
                    <h3>No Products Available</h3>
                    <p>Check back later for new arrivals</p>
                </div>
            }
        </div>
    </div>
</section>


